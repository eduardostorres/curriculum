---
import Layout from "@/layouts/Layout.astro";

import QuickNav from "@/components/QuickNav.astro";
import Certificates from "@/components/sections/Certificates.astro";
import Courses from "@/components/sections/Courses.astro";
import Education from "@/components/sections/Education.astro";
import Experience from "@/components/sections/Experience.astro";
import Hero from "@/components/sections/Hero.astro";
import Profile from "@/components/sections/Profile.astro";
import Skills from "@/components/sections/Skills.astro";

import { basics } from "@cv";
const { shortName } = basics;
---

<Layout title={`${shortName} | Curriculum Vitae`}>
  <main class="px-4 py-6 sm:px-6 lg:px-8">
    <Hero />
    <QuickNav />
    <Profile />
    <Experience />
    <Skills />
    <Education />
    <Certificates />
    <Courses />
  </main>
</Layout>
