---
import { basics } from "@cv";
import "@fontsource-variable/raleway";
import { translations } from "@/lib/translations";

interface Props {
  title: string;
}

const { title } = Astro.props;

const { image, summary, url, shortName } = basics;
const translationsJson = JSON.stringify(translations).replace(/</g, "\\u003c");
const fallbackMeta = {
  es: {
    title,
    description: summary
  },
  en: {
    title: `${shortName} | ${translations.en.meta.pageSuffix}`,
    description: translations.en.meta.description
  }
};
const fallbackMetaJson = JSON.stringify(fallbackMeta).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={summary} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="image" href={image} />

    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={summary} />
    <meta property="og:image" content="" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content={url.split("//")[1] ?? ""} />
    <meta property="twitter:url" content={url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={summary} />
    <meta name="twitter:image" content="" />
    <script is:inline id="translations-data" type="application/json" set:html={translationsJson}></script>
    <script is:inline id="meta-data" type="application/json" set:html={fallbackMetaJson}></script>
    <script is:inline>
      const translations = JSON.parse(document.getElementById('translations-data')?.textContent ?? '{}');
      const metaByLanguage = JSON.parse(document.getElementById('meta-data')?.textContent ?? '{}');
      const root = document.documentElement;
      const media = window.matchMedia('(prefers-color-scheme: dark)');

      const getNestedValue = (obj, path) => path.split('.').reduce((acc, key) => acc?.[key], obj);
      const replaceTemplate = (template, vars) =>
        template.replace(/\{(.*?)\}/g, (_, key) => vars[key.trim()] ?? '');

      const getPreferredLanguage = () => {
        const saved = localStorage.getItem('language');
        if (saved === 'es' || saved === 'en') return saved;

        const browserLanguages = navigator.languages ?? [navigator.language ?? 'es'];
        return browserLanguages.some((language) => language.toLowerCase().startsWith('en')) ? 'en' : 'es';
      };

      const getPreferredTheme = () => {
        const saved = localStorage.getItem('theme');
        if (saved === 'dark' || saved === 'light') return saved;
        return media.matches ? 'dark' : 'light';
      };

      const applyTheme = (theme) => {
        root.classList.toggle('dark', theme === 'dark');
        root.dataset.theme = theme;
        const button = document.getElementById('theme-toggle');
        const tooltip = document.getElementById('theme-toggle-tooltip');
        const badge = document.getElementById('theme-toggle-badge');
        const label = theme === 'dark'
          ? translations.en.controls.theme.light
          : translations.en.controls.theme.dark;

        if (button) {
          button.setAttribute('aria-label', label);
          button.setAttribute('title', label);
          button.setAttribute('data-tooltip-content', label);
        }

        if (tooltip) {
          tooltip.textContent = label;
        }

        if (badge) {
          badge.textContent = theme === 'dark'
            ? translations.en.controls.badges.dark
            : translations.en.controls.badges.light;
        }
      };

      const getFallbackValue = (element) => {
        if (!element.dataset.i18nFallback) {
          const fallbackValue = element instanceof HTMLImageElement
            ? element.alt
            : element.textContent ?? '';
          element.dataset.i18nFallback = fallbackValue;
        }

        return element.dataset.i18nFallback ?? '';
      };

      const getTemplateFallback = (element, key) => {
        if (!element.dataset.i18nTemplateFallback) {
          const fallbackValue = element instanceof HTMLImageElement
            ? element.alt
            : element.getAttribute('title') ?? element.getAttribute('aria-label') ?? '';
          element.dataset.i18nTemplateFallback = fallbackValue;
        }

        return element.dataset.i18nTemplateFallback ?? {
          'hero.emailTitle': `Envía un correo a ${element.getAttribute('data-email') ?? ''}`,
          'hero.visitProfile': `Visita mi ${element.getAttribute('data-network') ?? ''}`,
          'hero.profileAlt': `Foto de perfil de ${element.getAttribute('data-name') ?? ''}`
        }[key] ?? '';
      };

      const applyLanguage = (language) => {
        root.lang = language;
        root.dataset.language = language;

        const dictionary = language === 'en' ? translations.en : null;
        const meta = metaByLanguage[language] ?? metaByLanguage.es;

        document.title = meta.title;

        document.querySelector('meta[name="description"]')?.setAttribute('content', meta.description);
        document.querySelector('meta[property="og:title"]')?.setAttribute('content', meta.title);
        document.querySelector('meta[property="og:description"]')?.setAttribute('content', meta.description);
        document.querySelector('meta[name="twitter:title"]')?.setAttribute('content', meta.title);
        document.querySelector('meta[name="twitter:description"]')?.setAttribute('content', meta.description);

        document.querySelectorAll('[data-i18n]').forEach((element) => {
          const key = element.getAttribute('data-i18n');
          if (!key) return;

          const fallbackValue = getFallbackValue(element);
          const translated = dictionary ? getNestedValue(dictionary, key) : fallbackValue;
          element.textContent = translated ?? fallbackValue;
        });

        document.querySelectorAll('[data-i18n-template]').forEach((element) => {
          const key = element.getAttribute('data-i18n-template');
          if (!key) return;

          const template = dictionary ? getNestedValue(dictionary, key) : null;
          const fallback = getTemplateFallback(element, key);
          const value = template
            ? replaceTemplate(template, {
                email: element.getAttribute('data-email') ?? '',
                network: element.getAttribute('data-network') ?? '',
                name: element.getAttribute('data-name') ?? ''
              })
            : fallback;

          if (!value) return;

          if (element instanceof HTMLImageElement) {
            element.alt = value;
          } else {
            element.setAttribute('title', value);
            element.setAttribute('aria-label', value);
            if (element.hasAttribute('data-tooltip-content')) {
              element.setAttribute('data-tooltip-content', value);
            }
          }
        });

        const languageButton = document.getElementById('language-toggle');
        const languageTooltip = document.getElementById('language-toggle-tooltip');
        const languageBadge = document.getElementById('language-toggle-badge');
        const nextLanguageLabel = language === 'en'
          ? translations.en.controls.language.es
          : 'Switch to English';

        if (languageButton) {
          languageButton.setAttribute('aria-label', nextLanguageLabel);
          languageButton.setAttribute('title', nextLanguageLabel);
          languageButton.setAttribute('data-tooltip-content', nextLanguageLabel);
        }

        if (languageTooltip) {
          languageTooltip.textContent = nextLanguageLabel;
        }

        if (languageBadge) {
          languageBadge.textContent = language === 'en'
            ? translations.en.controls.badges.langEn
            : translations.en.controls.badges.langEs;
        }
      };

      const initialTheme = getPreferredTheme();
      const initialLanguage = getPreferredLanguage();

      applyTheme(initialTheme);
      applyLanguage(initialLanguage);

      window.__portfolioPreferences = {
        applyTheme,
        applyLanguage,
        getPreferredTheme,
        getPreferredLanguage
      };

      media.addEventListener('change', (event) => {
        if (!localStorage.getItem('theme')) {
          applyTheme(event.matches ? 'dark' : 'light');
        }
      });
    </script>
  </head>
  <body class="bg-white text-gray-900 dark:bg-gray-900 dark:text-gray-100 transition-colors duration-300">
    <div class="fixed bottom-4 left-1/2 z-50 flex w-[calc(100%-2rem)] max-w-max -translate-x-1/2 flex-row justify-center gap-2 sm:bottom-auto sm:left-auto sm:right-4 sm:top-4 sm:w-auto sm:translate-x-0">
      <div class="header-tooltip-wrapper">
        <button
          type="button"
          id="language-toggle"
          class="flex min-w-[8.5rem] items-center justify-center gap-2 rounded-md border border-gray-300 bg-white/85 px-3 py-2 text-sm font-semibold text-gray-700 shadow-sm backdrop-blur hover:bg-gray-100 dark:border-gray-600 dark:bg-gray-900/85 dark:text-gray-100 dark:hover:bg-gray-800 sm:min-w-0"
          aria-label="Switch to English"
          title="Switch to English"
          data-tooltip-content="Switch to English"
        >
          🌐 <span id="language-toggle-badge">ES</span>
        </button>
        <span class="header-tooltip" id="language-toggle-tooltip" role="tooltip">Switch to English</span>
      </div>
      <div class="header-tooltip-wrapper">
        <button
          type="button"
          id="theme-toggle"
          class="flex min-w-[8.5rem] items-center justify-center gap-2 rounded-md border border-gray-300 bg-white/85 px-3 py-2 text-sm font-semibold text-gray-700 shadow-sm backdrop-blur hover:bg-gray-100 dark:border-gray-600 dark:bg-gray-900/85 dark:text-gray-100 dark:hover:bg-gray-800 sm:min-w-0"
          aria-label="Switch to dark mode"
          title="Switch to dark mode"
          data-tooltip-content="Switch to dark mode"
        >
          🌓 <span id="theme-toggle-badge">Auto</span>
        </button>
        <span class="header-tooltip" id="theme-toggle-tooltip" role="tooltip">Switch to dark mode</span>
      </div>
    </div>
    <slot />
    <script is:inline>
      const initializePreferenceToggles = () => {
        const preferences = window.__portfolioPreferences;
        const themeToggle = document.getElementById('theme-toggle');
        const languageToggle = document.getElementById('language-toggle');

        themeToggle?.addEventListener('click', () => {
          const isDark = document.documentElement.classList.contains('dark');
          const nextTheme = isDark ? 'light' : 'dark';
          localStorage.setItem('theme', nextTheme);
          preferences?.applyTheme(nextTheme);
        });

        languageToggle?.addEventListener('click', () => {
          const currentLanguage = document.documentElement.lang === 'en' ? 'en' : 'es';
          const nextLanguage = currentLanguage === 'en' ? 'es' : 'en';
          localStorage.setItem('language', nextLanguage);
          preferences?.applyLanguage(nextLanguage);
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializePreferenceToggles, { once: true });
      } else {
        initializePreferenceToggles();
      }
    </script>
  </body>
</html>

<style is:global>
  html {
    font-family: monospace;
  }
</style>


<style is:global>
  .header-tooltip-wrapper {
    position: relative;
  }

  .header-tooltip-wrapper .header-tooltip {
    pointer-events: none;
    position: absolute;
    left: 50%;
    bottom: calc(100% + 0.5rem);
    transform: translateX(-50%);
    z-index: 60;
    white-space: nowrap;
    border-radius: 0.375rem;
    background: rgb(15 23 42);
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    color: white;
    opacity: 0;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    transition: opacity 0.2s ease;
  }

  .header-tooltip-wrapper:hover .header-tooltip,
  .header-tooltip-wrapper:focus-within .header-tooltip {
    opacity: 1;
  }


  .dark .header-tooltip-wrapper .header-tooltip {
    background: rgb(51 65 85);
  }

  @media (min-width: 640px) {
    .header-tooltip-wrapper .header-tooltip {
      left: auto;
      right: 0;
      bottom: auto;
      top: calc(100% + 0.5rem);
      transform: none;
    }
  }
</style>
