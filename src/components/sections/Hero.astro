---
import { basics, profiles } from "@cv";
import Section from "@/components/Section.astro";
import Mail from "@/icons/Mail.astro";
import LinkedIn from "@/icons/LinkedIn.astro";
import GitHub from "@/icons/GitHub.astro";
import CV from "@/icons/CV.astro";
import type { SocialIcon } from "@/types";

const { name, shortName, label, image, email } = basics;
const cvFile = "https://drive.google.com/file/d/1j4NtDcRoUGnE-aOG2UTUg9XMLnmhDdQO/view?usp=drive_link";
const cvTooltip = "Descarga mi CV";
const emailTooltip = `Enviar un correo a ${email}`;

const SOCIAL_ICONS: SocialIcon = {
  GitHub,
  LinkedIn
};
---

<Section>
  <div class="flex flex-col-reverse items-center justify-between gap-8 lg:flex-row">
    <div class="flex max-w-2xl flex-col items-center lg:items-start">
      <span class="pill mb-4">Diseño uniforme · Perfil profesional</span>
      <h1 class="font-display text-center text-5xl font-bold text-slate-900 dark:text-white lg:text-left">{shortName}</h1>
      <h2 class="mt-3 text-balance text-center text-xl text-slate-600 dark:text-slate-300 lg:text-left" data-i18n="hero.label">
        {label}
      </h2>
      <footer class="mt-6 flex flex-wrap justify-center gap-3 text-slate-500 dark:text-slate-400 lg:justify-start">
        {
          email && (
            <div class="tooltip-wrapper mt-1">
              <a
                class="hero-action"
                href={`mailto:${email}`}
                title={emailTooltip}
                aria-label={emailTooltip}
                data-i18n-template="hero.emailTitle"
                data-email={email}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Mail />
              </a>
              <span class="tooltip-bubble" role="tooltip" data-i18n-template="hero.emailTitle" data-email={email}>
                {emailTooltip}
              </span>
            </div>
          )
        }
        {
          profiles.map(({ network, url }) => {
            const Icon = SOCIAL_ICONS[network];

            return (
              <div class="tooltip-wrapper mt-1">
                <a
                  class="hero-action"
                  href={url}
                  title={`Visita mi ${network}`}
                  aria-label={`Visita mi ${network}`}
                  data-i18n-template="hero.visitProfile"
                  data-network={network}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon />
                </a>
                <span class="tooltip-bubble" role="tooltip" data-i18n-template="hero.visitProfile" data-network={network}>
                  {`Visita mi ${network}`}
                </span>
              </div>
            );
          })
        }
        <div class="tooltip-wrapper mt-1">
          <a
            class="hero-action"
            href={cvFile}
            title={cvTooltip}
            aria-label={cvTooltip}
            data-i18n-template="hero.downloadCv"
            target="_blank"
            rel="noopener noreferrer"
          >
            <CV />
          </a>
          <span class="tooltip-bubble" role="tooltip" data-i18n="hero.downloadCv">
            {cvTooltip}
          </span>
        </div>
      </footer>
    </div>
    <figure class="relative">
      <div class="absolute inset-0 -z-10 rounded-full bg-blue-500/20 blur-2xl" />
      <img
        class="h-40 w-40 rounded-full border border-white/70 object-cover p-1 shadow-2xl ring-4 ring-blue-500/25 dark:border-slate-800 dark:ring-blue-400/25"
        src={image}
        alt={`Foto de perfil de ${name}`}
        data-i18n-template="hero.profileAlt"
        data-name={name}
      />
    </figure>
  </div>
</Section>

<style>
  .hero-action {
    display: inline-flex;
    height: 3.25rem;
    width: 3.25rem;
    align-items: center;
    justify-content: center;
    border-radius: 1rem;
    border: 1px solid rgb(var(--ds-border) / 0.18);
    background: rgb(var(--ds-surface-muted) / 0.82);
    color: rgb(var(--ds-text-muted));
    box-shadow: 0 18px 30px -28px rgb(var(--ds-shadow) / 0.55);
    transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
  }

  .hero-action:hover {
    transform: translateY(-2px);
    border-color: rgb(var(--ds-primary) / 0.35);
    background: rgb(var(--ds-primary-soft) / 0.9);
    color: rgb(var(--ds-primary));
  }

  .tooltip-wrapper {
    position: relative;
  }

  .tooltip-bubble {
    pointer-events: none;
    position: absolute;
    left: 50%;
    top: calc(100% + 0.5rem);
    z-index: 10;
    transform: translateX(-50%);
    white-space: nowrap;
    border-radius: 9999px;
    background: rgb(15 23 42);
    padding: 0.35rem 0.8rem;
    font-size: 0.75rem;
    color: white;
    opacity: 0;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    transition: opacity 0.2s ease;
  }

  .tooltip-wrapper:hover .tooltip-bubble,
  .tooltip-wrapper:focus-within .tooltip-bubble {
    opacity: 1;
  }

  :global(.dark) .tooltip-bubble {
    background: rgb(51 65 85);
  }
</style>
