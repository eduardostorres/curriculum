---
import { basics, profiles } from "@cv";
import Section from "@/components/Section.astro";
import Mail from "@/icons/Mail.astro";
import LinkedIn from "@/icons/LinkedIn.astro";
import GitHub from "@/icons/GitHub.astro";
import CV from "@/icons/CV.astro";
import type { SocialIcon } from "@/types";

const { name, shortName, label, image, email } = basics;
const cvFile = "https://drive.google.com/file/d/1j4NtDcRoUGnE-aOG2UTUg9XMLnmhDdQO/view?usp=drive_link";
const cvTooltip = "Descarga mi CV";

const SOCIAL_ICONS: SocialIcon = {
  GitHub,
  LinkedIn
};
---

<Section>
  <div class="flex flex-col-reverse lg:flex-row items-center justify-between gap-4">
    <div class="flex flex-col items-center lg:items-start">
      <h1 class="flex font-bold text-4xl text-center font-sans">{shortName}</h1>
      <h2
        class="text-gray-400 dark:text-gray-300 text-balance text-lg mt-2"
        data-i18n="hero.label"
      >
        {label}
      </h2>
      <footer class="text-gray-500 dark:text-gray-400 flex flex-wrap justify-center lg:justify-start gap-3 mt-3">
        {
          email && (
            <a
              class="mt-1 text-slate-500 dark:text-slate-400 inline-flex items-center justify-center border-[1px] border-solid border-gray-200 dark:border-gray-700 p-1 w-12 h-12 rounded-md hover:bg-slate-100 dark:hover:bg-slate-800 hover:border-[1px] hover:border-solid hover:border-gray-200 dark:hover:border-gray-600"
              href={`mailto:${email}`}
              title={`Enviar un correo a ${email}`}
              data-i18n-template="hero.emailTitle"
              data-email={email}
              target="_blank"
              rel="noopener noreferrer"
            >
              <Mail />
            </a>
          )
        }
        <div class="group relative mt-1">
          <a
            class="text-slate-500 dark:text-slate-400 inline-flex items-center justify-center border-[1px] border-solid border-gray-200 dark:border-gray-700 p-1 w-12 h-12 rounded-md hover:bg-slate-100 dark:hover:bg-slate-800 hover:border-[1px] hover:border-solid hover:border-gray-200 dark:hover:border-gray-600"
            href={cvFile}
            title={cvTooltip}
            aria-label={cvTooltip}
            data-i18n-template="hero.downloadCv"
            target="_blank"
            rel="noopener noreferrer"
          >
            <CV />
          </a>
          <span
            class="pointer-events-none absolute left-1/2 top-full z-10 mt-2 -translate-x-1/2 whitespace-nowrap rounded-md bg-slate-900 px-3 py-1 text-xs text-white opacity-0 shadow-lg transition-opacity duration-200 group-hover:opacity-100 group-focus-within:opacity-100 dark:bg-slate-700"
            role="tooltip"
            data-i18n="hero.downloadCv"
          >
            {cvTooltip}
          </span>
        </div>
        {
          profiles.map(({ network, url }) => {
            const Icon = SOCIAL_ICONS[network];

            return (
              <a
                class="mt-1 text-slate-500 dark:text-slate-400 inline-flex items-center justify-center border-[1px] border-solid border-gray-200 dark:border-gray-700 p-1 w-12 h-12 rounded-md hover:bg-slate-100 dark:hover:bg-slate-800 hover:border-[1px] hover:border-solid hover:border-gray-200 dark:hover:border-gray-600"
                href={url}
                title={`Visita mi ${network}`}
                data-i18n-template="hero.visitProfile"
                data-network={network}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon />
              </a>
            );
          })
        }
      </footer>
    </div>
    <figure>
      <img
        class="w-36 h-36 p-1 object-cover rounded-full ring-2 ring-gray-500 dark:ring-gray-400"
        src={image}
        alt={`Foto de perfil de ${name}`}
        data-i18n-template="hero.profileAlt"
        data-name={name}
      />
    </figure>
  </div>
</Section>

<style>
  footer a {
    transition: all 0.3s ease;
  }
</style>
