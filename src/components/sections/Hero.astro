---
import { basics, profiles } from "@cv";
import Section from "@/components/Section.astro";
import Mail from "@/icons/Mail.astro";
import LinkedIn from "@/icons/LinkedIn.astro";
import GitHub from "@/icons/GitHub.astro";
import CV from "@/icons/CV.astro";
import type { SocialIcon } from "@/types";

const { name, shortName, label, image, email } = basics;
const cvFile = "https://drive.google.com/file/d/1j4NtDcRoUGnE-aOG2UTUg9XMLnmhDdQO/view?usp=drive_link";
const cvTooltip = "Descarga mi CV";
const emailTooltip = `Enviar un correo a ${email}`;

const SOCIAL_ICONS: SocialIcon = {
  GitHub,
  LinkedIn
};
---

<Section>
  <div class="section-card flex flex-col-reverse items-center justify-between gap-8 px-6 py-8 lg:flex-row lg:px-10">
    <div class="flex flex-col items-center lg:items-start">
      <h1 class="flex text-center font-sans text-4xl font-bold tracking-tight lg:text-left lg:text-5xl" style="font-family: var(--ds-font-display); color: var(--ds-text);">{shortName}</h1>
      <h2
        class="section-subtitle mt-3 text-balance text-center text-lg lg:text-left"
        data-i18n="hero.label"
      >
        {label}
      </h2>
      <footer class="mt-5 flex flex-wrap justify-center gap-3 text-gray-500 lg:justify-start">
        {
          email && (
            <div class="tooltip-wrapper mt-1">
              <a
                class="icon-button"
                href={`mailto:${email}`}
                title={emailTooltip}
                aria-label={emailTooltip}
                data-i18n-template="hero.emailTitle"
                data-email={email}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Mail />
              </a>
              <span class="tooltip-bubble" role="tooltip" data-i18n-template="hero.emailTitle" data-email={email}>
                {emailTooltip}
              </span>
            </div>
          )
        }
        {
          profiles.map(({ network, url }) => {
            const Icon = SOCIAL_ICONS[network];

            return (
              <div class="tooltip-wrapper mt-1">
                <a
                  class="icon-button"
                  href={url}
                  title={`Visita mi ${network}`}
                  aria-label={`Visita mi ${network}`}
                  data-i18n-template="hero.visitProfile"
                  data-network={network}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon />
                </a>
                <span class="tooltip-bubble" role="tooltip" data-i18n-template="hero.visitProfile" data-network={network}>
                  {`Visita mi ${network}`}
                </span>
              </div>
            );
          })
        }
        <div class="tooltip-wrapper mt-1">
          <a
            class="icon-button"
            href={cvFile}
            title={cvTooltip}
            aria-label={cvTooltip}
            data-i18n-template="hero.downloadCv"
            target="_blank"
            rel="noopener noreferrer"
          >
            <CV />
          </a>
          <span class="tooltip-bubble" role="tooltip" data-i18n="hero.downloadCv">
            {cvTooltip}
          </span>
        </div>
      </footer>
    </div>
    <figure class="relative">
      <img
        class="h-36 w-36 rounded-[2rem] border object-cover p-1 shadow-xl"
        style="background: var(--ds-surface-strong); border-color: var(--ds-border); box-shadow: 0 0 0 6px var(--ds-accent-soft), var(--ds-shadow);"
        src={image}
        alt={`Foto de perfil de ${name}`}
        data-i18n-template="hero.profileAlt"
        data-name={name}
      />
    </figure>
  </div>
</Section>

<style>
  footer a {
    transition: all 0.3s ease;
  }

  .tooltip-wrapper {
    position: relative;
  }

  .tooltip-bubble {
    pointer-events: none;
    position: absolute;
    left: 50%;
    top: 100%;
    z-index: 10;
    margin-top: 0.5rem;
    transform: translateX(-50%);
    white-space: nowrap;
    border-radius: 0.75rem;
    background: var(--ds-surface-strong);
    border: 1px solid var(--ds-border);
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    color: var(--ds-text);
    opacity: 0;
    box-shadow: var(--ds-shadow);
    transition: opacity 0.2s ease;
  }

  .tooltip-wrapper:hover .tooltip-bubble,
  .tooltip-wrapper:focus-within .tooltip-bubble {
    opacity: 1;
  }
</style>
