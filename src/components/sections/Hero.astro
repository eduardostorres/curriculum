---
import { basics, profiles } from "@cv";
import Section from "@/components/Section.astro";
import Mail from "@/icons/Mail.astro";
import LinkedIn from "@/icons/LinkedIn.astro";
import GitHub from "@/icons/GitHub.astro";
import CV from "@/icons/CV.astro";
import type { SocialIcon } from "@/types";

const { name, shortName, label, image, email } = basics;
const cvFile = "https://drive.google.com/file/d/1j4NtDcRoUGnE-aOG2UTUg9XMLnmhDdQO/view?usp=drive_link";

const SOCIAL_ICONS: SocialIcon = {
  GitHub,
  LinkedIn
};
---

<Section>
  <div class="flex flex-col-reverse items-center justify-between gap-4 lg:flex-row">
    <div class="flex flex-col items-center lg:items-start">
      <h1 class="flex text-center font-sans text-4xl font-bold">{shortName}</h1>
      <h2
        class="mt-2 text-balance text-lg text-gray-400 dark:text-gray-300"
        data-i18n="hero.label"
      >
        {label}
      </h2>
      <p
        class="mt-4 max-w-2xl text-center text-sm leading-6 text-gray-500 dark:text-gray-300 lg:text-left"
        data-i18n="hero.quickHint"
      >
        Explora rápidamente cada sección, cambia el idioma o el tema, y descarga el CV con un solo clic.
      </p>
      <footer class="mt-4 flex flex-wrap justify-center gap-3 text-gray-500 dark:text-gray-400 lg:justify-start">
        {
          email && (
            <a
              class="mt-1 inline-flex h-12 w-12 items-center justify-center rounded-md border border-solid border-gray-200 p-1 text-slate-500 transition hover:border-gray-200 hover:bg-slate-100 dark:border-gray-700 dark:text-slate-400 dark:hover:border-gray-600 dark:hover:bg-slate-800"
              href={`mailto:${email}`}
              title={`Enviar un correo a ${email}`}
              data-i18n-template="hero.emailTitle"
              data-email={email}
              target="_blank"
              rel="noopener noreferrer"
            >
              <Mail />
            </a>
          )
        }
        <a
          class="mt-1 inline-flex items-center gap-2 rounded-full bg-sky-600 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900"
          href={cvFile}
          target="_blank"
          rel="noopener noreferrer"
        >
          <CV />
          <span data-i18n="hero.downloadCv">Descargar CV</span>
        </a>
        {
          profiles.map(({ network, url }) => {
            const Icon = SOCIAL_ICONS[network];

            return (
              <a
                class="mt-1 inline-flex h-12 w-12 items-center justify-center rounded-md border border-solid border-gray-200 p-1 text-slate-500 transition hover:border-gray-200 hover:bg-slate-100 dark:border-gray-700 dark:text-slate-400 dark:hover:border-gray-600 dark:hover:bg-slate-800"
                href={url}
                title={`Visita mi ${network}`}
                data-i18n-template="hero.visitProfile"
                data-network={network}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon />
              </a>
            );
          })
        }
      </footer>
    </div>
    <figure>
      <img
        class="h-36 w-36 rounded-full object-cover p-1 ring-2 ring-gray-500 dark:ring-gray-400"
        src={image}
        alt={`Foto de perfil de ${name}`}
        data-i18n-template="hero.profileAlt"
        data-name={name}
      />
    </figure>
  </div>
</Section>
