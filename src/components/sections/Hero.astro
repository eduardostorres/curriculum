---
import { basics, profiles } from "@cv";
import Section from "@/components/Section.astro";
import Mail from "@/icons/Mail.astro";
import LinkedIn from "@/icons/LinkedIn.astro";
import GitHub from "@/icons/GitHub.astro";
import CV from "@/icons/CV.astro";
import type { SocialIcon } from "@/types";

const { name, shortName, label, image, email } = basics;
const cvFile = "https://drive.google.com/file/d/1j4NtDcRoUGnE-aOG2UTUg9XMLnmhDdQO/view?usp=drive_link";
const cvTooltip = "Descarga mi CV";

const SOCIAL_ICONS: SocialIcon = {
  GitHub,
  LinkedIn
};
---

<Section>
  <div class="flex flex-col-reverse items-start justify-between gap-8 lg:flex-row lg:items-center">
    <div class="w-full">
      <p class="text-xs font-semibold uppercase tracking-[0.35em] text-neutral-500">Curriculum Vitae</p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-white sm:text-5xl">{shortName}</h1>
      <h2 class="mt-4 max-w-2xl text-lg text-neutral-400" data-i18n="hero.label">
        {label}
      </h2>
      <footer class="mt-8 flex flex-wrap gap-3 text-neutral-300">
        {
          email && (
            <a
              class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/5 transition hover:border-white/20 hover:bg-white/10"
              href={`mailto:${email}`}
              title={`Enviar un correo a ${email}`}
              data-i18n-template="hero.emailTitle"
              data-email={email}
              target="_blank"
              rel="noopener noreferrer"
            >
              <Mail />
            </a>
          )
        }
        <div class="group relative">
          <a
            class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/5 transition hover:border-white/20 hover:bg-white/10"
            href={cvFile}
            title={cvTooltip}
            aria-label={cvTooltip}
            target="_blank"
            rel="noopener noreferrer"
          >
            <CV />
          </a>
          <span
            class="pointer-events-none absolute left-1/2 top-full z-10 mt-2 -translate-x-1/2 whitespace-nowrap rounded-full border border-white/10 bg-neutral-950 px-3 py-1 text-[11px] uppercase tracking-[0.25em] text-neutral-300 opacity-0 transition-opacity duration-200 group-hover:opacity-100 group-focus-within:opacity-100"
            role="tooltip"
          >
            {cvTooltip}
          </span>
        </div>
        {
          profiles.map(({ network, url }) => {
            const Icon = SOCIAL_ICONS[network];

            return (
              <a
                class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/5 transition hover:border-white/20 hover:bg-white/10"
                href={url}
                title={`Visita mi ${network}`}
                data-i18n-template="hero.visitProfile"
                data-network={network}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon />
              </a>
            );
          })
        }
      </footer>
    </div>
    <figure class="mx-auto shrink-0 lg:mx-0">
      <img
        class="h-32 w-32 rounded-full border border-white/10 object-cover p-1 grayscale sm:h-36 sm:w-36"
        src={image}
        alt={`Foto de perfil de ${name}`}
        data-i18n-template="hero.profileAlt"
        data-name={name}
      />
    </figure>
  </div>
</Section>
