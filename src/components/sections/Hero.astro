---
import { basics, profiles, work, skills } from "@cv";
import Section from "@/components/Section.astro";
import Mail from "@/icons/Mail.astro";
import LinkedIn from "@/icons/LinkedIn.astro";
import GitHub from "@/icons/GitHub.astro";
import CV from "@/icons/CV.astro";
import type { SocialIcon } from "@/types";

const { name, shortName, label, image, email } = basics;
const cvFile = "https://drive.google.com/file/d/1j4NtDcRoUGnE-aOG2UTUg9XMLnmhDdQO/view?usp=drive_link";
const cvTooltip = "Descarga mi CV";
const featuredSkills = skills.slice(0, 4).map(({ name }) => name);
const yearsExperience = new Date().getFullYear() - new Date(work.at(-1)?.startDate ?? new Date().toISOString()).getFullYear();

const SOCIAL_ICONS: SocialIcon = {
  GitHub,
  LinkedIn
};
---

<Section className="pt-2 md:pt-6">
  <div class="grid gap-8 border-b border-slate-200 pb-10 dark:border-slate-800 lg:grid-cols-[1.35fr,0.85fr] lg:items-center">
    <div class="space-y-6">
      <div class="space-y-4">
        <p class="text-sm font-medium uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400">
          Ciudad de México · Full stack developer
        </p>
        <div class="space-y-3">
          <h1 class="max-w-3xl text-4xl font-bold tracking-tight text-slate-900 dark:text-white md:text-5xl font-sans">
            {shortName}
          </h1>
          <h2 class="max-w-2xl text-lg leading-8 text-slate-600 dark:text-slate-300" data-i18n="hero.label">
            {label}
          </h2>
          <p class="max-w-3xl text-base leading-7 text-slate-600 dark:text-slate-300" data-i18n="hero.summaryLead">
            Desarrollo productos web claros, rápidos y mantenibles, uniendo una experiencia visual limpia con lógica de negocio sólida.
          </p>
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        {
          email && (
            <a
              class="inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-slate-800 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-100"
              href={`mailto:${email}`}
              title={`Enviar un correo a ${email}`}
              data-i18n-template="hero.emailTitle"
              data-email={email}
            >
              <Mail />
              <span data-i18n="hero.ctaEmail">Hablemos por correo</span>
            </a>
          )
        }

        <a
          class="inline-flex items-center gap-2 rounded-lg border border-slate-300 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-900"
          href={cvFile}
          title={cvTooltip}
          aria-label={cvTooltip}
          target="_blank"
          rel="noopener noreferrer"
        >
          <CV />
          <span data-i18n="hero.ctaCv">Ver CV</span>
        </a>
      </div>

      <dl class="grid gap-4 sm:grid-cols-3">
        <div class="rounded-xl border border-slate-200 p-4 dark:border-slate-800">
          <dt class="text-sm text-slate-500 dark:text-slate-400" data-i18n="hero.stats.experienceLabel">Experiencia</dt>
          <dd class="mt-2 text-2xl font-semibold text-slate-900 dark:text-white">{yearsExperience}+</dd>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-300" data-i18n="hero.stats.experienceValue">años creando productos web</p>
        </div>
        <div class="rounded-xl border border-slate-200 p-4 dark:border-slate-800">
          <dt class="text-sm text-slate-500 dark:text-slate-400" data-i18n="hero.stats.focusLabel">Enfoque</dt>
          <dd class="mt-2 text-lg font-semibold text-slate-900 dark:text-white" data-i18n="hero.stats.focusValue">Frontend + Backend</dd>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-300" data-i18n="hero.stats.focusBody">Interfaces limpias, APIs y datos consistentes</p>
        </div>
        <div class="rounded-xl border border-slate-200 p-4 dark:border-slate-800">
          <dt class="text-sm text-slate-500 dark:text-slate-400" data-i18n="hero.stats.stackLabel">Stack</dt>
          <dd class="mt-2 text-lg font-semibold text-slate-900 dark:text-white">Astro · PHP · TS</dd>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-300" data-i18n="hero.stats.stackBody">Soluciones rápidas, escalables y mantenibles</p>
        </div>
      </dl>

      <div class="space-y-3">
        <p class="text-sm font-medium uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400" data-i18n="hero.stackTitle">Tecnologías clave</p>
        <div class="flex flex-wrap gap-2">
          {featuredSkills.map((item) => <span class="rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 dark:border-slate-700 dark:text-slate-300">{item}</span>)}
        </div>
      </div>

      <footer class="flex flex-wrap gap-3 text-slate-500 dark:text-slate-400">
        {
          profiles.map(({ network, url }) => {
            const Icon = SOCIAL_ICONS[network];

            return (
              <a
                class="inline-flex items-center gap-2 text-sm font-medium text-slate-600 transition hover:text-slate-900 dark:text-slate-300 dark:hover:text-white"
                href={url}
                title={`Visita mi ${network}`}
                data-i18n-template="hero.visitProfile"
                data-network={network}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon />
                <span>{network}</span>
              </a>
            );
          })
        }
      </footer>
    </div>

    <aside class="flex justify-center lg:justify-end">
      <figure class="w-full max-w-sm rounded-2xl border border-slate-200 p-6 dark:border-slate-800">
        <img
          class="mx-auto h-32 w-32 rounded-full object-cover"
          src={image}
          alt={`Foto de perfil de ${name}`}
          data-i18n-template="hero.profileAlt"
          data-name={name}
        />
        <figcaption class="mt-5 text-center">
          <p class="text-lg font-semibold text-slate-900 dark:text-white">{shortName}</p>
          <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300" data-i18n="hero.cardCopy">
            Perfil orientado a claridad, rendimiento y mantenimiento a largo plazo.
          </p>
        </figcaption>
      </figure>
    </aside>
  </div>
</Section>
