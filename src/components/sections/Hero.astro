---
import { basics, profiles } from "@cv";
import Section from "@/components/Section.astro";
import Mail from "@/icons/Mail.astro";
import LinkedIn from "@/icons/LinkedIn.astro";
import GitHub from "@/icons/GitHub.astro";
import CV from "@/icons/CV.astro";
import type { SocialIcon } from "@/types";

const { name, shortName, label, image, email } = basics;
const cvFile = "https://drive.google.com/file/d/1j4NtDcRoUGnE-aOG2UTUg9XMLnmhDdQO/view?usp=drive_link";
const cvTooltip = "Descarga mi CV";
const emailTooltip = `Enviar un correo a ${email}`;

const SOCIAL_ICONS: SocialIcon = {
  GitHub,
  LinkedIn
};
---

<Section>
  <div class="flex flex-col-reverse items-center justify-between gap-8 lg:flex-row">
    <div class="flex max-w-2xl flex-col items-center text-center lg:items-start lg:text-left">
      <span class="eyebrow">Portfolio</span>
      <h1 class="font-sans text-4xl font-bold tracking-tight text-[var(--text-primary)] sm:text-5xl">{shortName}</h1>
      <h2
        class="mt-3 max-w-2xl text-balance text-lg text-[var(--text-secondary)] sm:text-xl"
        data-i18n="hero.label"
      >
        {label}
      </h2>
      <footer class="mt-6 flex flex-wrap justify-center gap-3 text-[var(--text-secondary)] lg:justify-start">
        {
          email && (
            <div class="tooltip-wrapper mt-1">
              <a
                class="hero-action"
                href={`mailto:${email}`}
                title={emailTooltip}
                aria-label={emailTooltip}
                data-i18n-template="hero.emailTitle"
                data-email={email}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Mail />
              </a>
              <span class="tooltip-bubble" role="tooltip" data-i18n-template="hero.emailTitle" data-email={email}>
                {emailTooltip}
              </span>
            </div>
          )
        }
        {
          profiles.map(({ network, url }) => {
            const Icon = SOCIAL_ICONS[network];

            return (
              <div class="tooltip-wrapper mt-1">
                <a
                  class="hero-action"
                  href={url}
                  title={`Visita mi ${network}`}
                  aria-label={`Visita mi ${network}`}
                  data-i18n-template="hero.visitProfile"
                  data-network={network}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon />
                </a>
                <span class="tooltip-bubble" role="tooltip" data-i18n-template="hero.visitProfile" data-network={network}>
                  {`Visita mi ${network}`}
                </span>
              </div>
            );
          })
        }
        <div class="tooltip-wrapper mt-1">
          <a
            class="hero-action"
            href={cvFile}
            title={cvTooltip}
            aria-label={cvTooltip}
            data-i18n-template="hero.downloadCv"
            target="_blank"
            rel="noopener noreferrer"
          >
            <CV />
          </a>
          <span class="tooltip-bubble" role="tooltip" data-i18n="hero.downloadCv">
            {cvTooltip}
          </span>
        </div>
      </footer>
    </div>
    <figure class="relative">
      <div class="absolute inset-0 rounded-full bg-[var(--accent)]/15 blur-2xl"></div>
      <img
        class="relative h-40 w-40 rounded-full border border-[var(--surface-border)] bg-[var(--surface-strong)] p-1.5 object-cover shadow-[var(--shadow-soft)]"
        src={image}
        alt={`Foto de perfil de ${name}`}
        data-i18n-template="hero.profileAlt"
        data-name={name}
      />
    </figure>
  </div>
</Section>

<style>
  .hero-action {
    display: inline-flex;
    height: 3.25rem;
    width: 3.25rem;
    align-items: center;
    justify-content: center;
    border-radius: 1rem;
    border: 1px solid var(--surface-border);
    background: var(--surface-strong);
    box-shadow: var(--shadow-soft);
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .hero-action:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 45%, transparent);
    background: var(--surface-soft);
  }

  .tooltip-wrapper {
    position: relative;
  }

  .tooltip-bubble {
    pointer-events: none;
    position: absolute;
    left: 50%;
    top: calc(100% + 0.5rem);
    z-index: 10;
    transform: translateX(-50%);
    white-space: nowrap;
    border-radius: 9999px;
    border: 1px solid var(--surface-border);
    background: var(--surface-strong);
    padding: 0.35rem 0.8rem;
    font-size: 0.75rem;
    color: var(--text-secondary);
    opacity: 0;
    box-shadow: var(--shadow-soft);
    transition: opacity 0.2s ease;
  }

  .tooltip-wrapper:hover .tooltip-bubble,
  .tooltip-wrapper:focus-within .tooltip-bubble {
    opacity: 1;
  }
</style>
