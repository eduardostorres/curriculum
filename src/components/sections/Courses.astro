---
import Section from "../Section.astro";
import { courses } from "@cv";
---

<Section title="Cursos" translationKey="sections.courses">
  <ul class="mb-4 flex flex-col gap-4">
    {
      courses.map(({ platform, summary, typePlatform }, index) => {
        return (
          <li class="ds-card p-5">
            <article>
              <header class="flex">
                <div>
                  <h3 class="ds-item-title text-lg">{platform}</h3>
                  <p class="ds-item-meta mt-1 text-sm" data-i18n={`courses.items.${index}.typePlatform`}>{typePlatform}</p>
                </div>
              </header>
              <footer>
                <p class="ds-copy mt-3 text-sm" data-i18n={`courses.items.${index}.summary`}>{summary}</p>
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>
