---
import Section from "../Section.astro";
import { courses } from "@cv";
---

<Section title="Cursos" translationKey="sections.courses">
  <ul class="grid gap-4 md:grid-cols-2 mb-4">
    {
      courses.map(({ platform, summary, typePlatform }, index) => {
        const bulletPoints = summary.split("\n\n");
        return (
          <li>
            <article class="h-full rounded-2xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-900">
              <header>
                <h3 class="text-xl font-bold text-slate-900 dark:text-white font-sans">{platform}</h3>
                <p class="mt-2 text-sm font-medium text-slate-500 dark:text-slate-400" data-i18n={`courses.items.${index}.typePlatform`}>{typePlatform}</p>
              </header>
              <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-600 dark:text-slate-300">
                {bulletPoints.map((point, pointIndex) => <li class="flex gap-3"><span class="mt-2 h-2 w-2 flex-none rounded-full bg-amber-500" /><span data-i18n={pointIndex === 0 ? `courses.items.${index}.summary` : undefined}>{point}</span></li>)}
              </ul>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>
