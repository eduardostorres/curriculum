---
import Section from "../Section.astro";
import { courses } from "@cv";
---

<Section title="Cursos" translationKey="sections.courses">
  <ul class="stack-list mb-4">
    {
      courses.map(({ platform, summary, typePlatform }, index) => {
        return (
          <li>
            <article class="section-card px-6 py-5">
              <header class="flex">
                <div>
                  <h3 class="card-title mt-1 text-xl">{platform}</h3>
                  <p class="card-eyebrow mt-1" data-i18n={`courses.items.${index}.typePlatform`}>{typePlatform}</p>
                </div>
              </header>
              <footer>
                <p class="card-copy mt-3" data-i18n={`courses.items.${index}.summary`}>{summary}</p>
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>
