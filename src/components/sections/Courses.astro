---
import Section from "../Section.astro";
import { courses } from "@cv";
---

<Section title="Cursos" translationKey="sections.courses" eyebrow="Growth">
  <ul class="card-grid">
    {
      courses.map(({ platform, summary, typePlatform }, index) => {
        return (
          <li>
            <article class="info-card">
              <header>
                <h3 class="item-title">{platform}</h3>
                <p class="item-subtitle" data-i18n={`courses.items.${index}.typePlatform`}>{typePlatform}</p>
              </header>
              <footer>
                <p class="item-copy" data-i18n={`courses.items.${index}.summary`}>{summary}</p>
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>
