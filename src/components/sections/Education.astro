---
import Section from "../Section.astro";
import { education } from "@cv";
---

<Section title="Educación" translationKey="sections.education">
  <ul class="space-y-5">
    {
      education.map(({ institution, area, summary }, index) => {
        return (
          <li class="border-b border-white/10 pb-5 last:border-b-0 last:pb-0">
            <article>
              <header>
                <h3 class="text-lg font-medium text-white">{institution}</h3>
                <p class="mt-1 text-sm uppercase tracking-[0.24em] text-neutral-500" data-i18n={`education.items.${index}.area`}>{area}</p>
              </header>
              <footer>
                <p class="mt-3 max-w-3xl text-sm leading-7 text-neutral-400" data-i18n={`education.items.${index}.summary`}>{summary}</p>
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>
