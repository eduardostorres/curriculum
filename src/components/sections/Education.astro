---
import Section from "../Section.astro";
import { education } from "@cv";
---

<Section title="Educación" translationKey="sections.education">
  <ul class="flex flex-col gap-4">
    {
      education.map(({ institution, area, summary }, index) => {
        return (
          <li class="ds-card p-5">
            <article>
              <header class="flex">
                <div>
                  <h3 class="ds-item-title text-lg">{institution}</h3>
                  <p class="ds-item-meta mt-1 text-sm" data-i18n={`education.items.${index}.area`}>{area}</p>
                </div>
              </header>

              <footer>
                <p class="ds-copy mt-3 text-sm" data-i18n={`education.items.${index}.summary`}>{summary}</p>
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>
