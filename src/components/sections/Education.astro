---
import Section from "../Section.astro";
import { education } from "@cv";
---

<Section title="Educación" translationKey="sections.education" eyebrow="Learning">
  <ul class="card-grid">
    {
      education.map(({ institution, area, summary }, index) => {
        return (
          <li>
            <article class="info-card">
              <header>
                <h3 class="item-title">{institution}</h3>
                <p class="item-subtitle" data-i18n={`education.items.${index}.area`}>{area}</p>
              </header>

              <footer>
                <p class="item-copy" data-i18n={`education.items.${index}.summary`}>{summary}</p>
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>
