---
import Section from "../Section.astro";
import { education } from "@cv";
---

<Section title="Educación" translationKey="sections.education">
  <ul class="flex flex-col gap-4">
    {
      education.map(({ institution, area, summary }, index) => {
        return (
          <li>
            <article class="item-card">
              <header>
                <h3 class="item-title">{institution}</h3>
                <p class="item-subtitle mt-2 text-base font-semibold" data-i18n={`education.items.${index}.area`}>
                  {area}
                </p>
              </header>

              <footer>
                <p class="item-copy" data-i18n={`education.items.${index}.summary`}>{summary}</p>
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>
