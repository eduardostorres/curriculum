---
import Section from "../Section.astro";
import { education } from "@cv";
---

<Section title="Educación" translationKey="sections.education">
  <ul class="stack-list">
    {
      education.map(({ institution, area, summary }, index) => {
        return (
          <li>
            <article class="section-card px-6 py-5">
              <header class="flex">
                <div>
                  <h3 class="card-title mt-1">{institution}</h3>
                  <p class="card-eyebrow mt-1" data-i18n={`education.items.${index}.area`}>{area}</p>
                </div>
              </header>

              <footer>
                <p class="card-copy mt-3" data-i18n={`education.items.${index}.summary`}>{summary}</p>
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>
