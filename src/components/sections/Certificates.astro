---
import Section from "../Section.astro";
import { certificates } from "@cv";
---

<Section title="Certificados" translationKey="sections.certificates">
  <ul class="stack-list">
    {
      certificates.map(({ name, issuer, summary }, index) => {
        return (
          <li>
            <article class="section-card px-6 py-5">
              <header class="flex">
                <div>
                  <h3 class="card-title mt-1">{name}</h3>
                  <p class="card-eyebrow mt-1">{issuer}</p>
                </div>
              </header>
              <footer>
                <p class="card-copy mt-3" data-i18n={`certificates.items.${index}.summary`}>{summary}</p>
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>
