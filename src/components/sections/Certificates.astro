---
import Section from "../Section.astro";
import { certificates } from "@cv";
---

<Section title="Certificados" translationKey="sections.certificates">
  <ul class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {
      certificates.map(({ name, issuer, summary }) => {
        const bulletPoints = summary.split("\n\n");
        return (
          <li>
            <article class="flex h-full flex-col rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
              <header>
                <h3 class="text-lg font-bold leading-7 text-slate-900 dark:text-white font-sans">{name}</h3>
                <p class="mt-2 text-sm font-medium text-slate-500 dark:text-slate-400">{issuer}</p>
              </header>
              <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-600 dark:text-slate-300">
                {bulletPoints.map((point) => <li class="flex gap-3"><span class="mt-2 h-2 w-2 flex-none rounded-full bg-emerald-500" /><span>{point}</span></li>)}
              </ul>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>
