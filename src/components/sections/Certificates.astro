---
import Section from "../Section.astro";
import { certificates } from "@cv";
---

<Section title="Certificados" translationKey="sections.certificates" eyebrow="Proof">
  <ul class="card-grid">
    {
      certificates.map(({ name, issuer, summary }, index) => {
        return (
          <li>
            <article class="info-card">
              <header>
                <h3 class="item-title">{name}</h3>
                <p class="item-subtitle">{issuer}</p>
              </header>
              <footer>
                <p class="item-copy" data-i18n={`certificates.items.${index}.summary`}>{summary}</p>
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>
