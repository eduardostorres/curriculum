---
import Section from "../Section.astro";
import { languages } from "@cv";
---

<Section title="Idiomas">
  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
    <ul class="flex flex-wrap gap-3">
      {
        languages.map(({ language, fluency }) => (
          <li class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600 shadow-sm dark:border-slate-700 dark:bg-slate-800/70 dark:text-slate-300">
            <span class="font-semibold text-slate-900 dark:text-white">{language}</span>
            <span class="mx-2 text-slate-300 dark:text-slate-600">•</span>
            <span>{fluency}</span>
          </li>
        ))
      }
    </ul>
  </div>
</Section>
