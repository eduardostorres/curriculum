---
import Section from "../Section.astro";
import { interests } from "@cv";
---

<Section title="Intereses">
  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
    <ul class="flex flex-wrap gap-2">
      {
        interests.map(({ name }) => (
          <li class="rounded-full border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-600 dark:border-slate-700 dark:bg-slate-800/70 dark:text-slate-300">
            {name}
          </li>
        ))
      }
    </ul>
  </div>
</Section>
