---
import Section from "../Section.astro";

import { work } from "@cv";
---

<Section title="Experiencia laboral" translationKey="sections.experience">
  <ul class="space-y-6 border-l border-white/10 pl-6">
    {
      work.map(({ name, startDate, endDate, position, summary, url }, index) => {
        const startYear = new Date(startDate).getFullYear();
        const endYear = endDate != null ? new Date(endDate).getFullYear() : "Actual";

        return (
          <li class="relative">
            <div class="absolute -left-[1.95rem] top-2 h-2.5 w-2.5 rounded-full border border-white/20 bg-white/70" />
            <div class="flex flex-col gap-2">
              <div class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between">
                <h3 class="text-lg font-medium text-white">
                  <span data-i18n={`experience.items.${index}.position`}>{position}</span>{" "}
                  <span class="text-neutral-500" data-i18n={`experience.items.${index}.at`}>en</span>{" "}
                  <a class="text-neutral-300 transition hover:text-white" href={url} target="_blank" rel="noopener noreferrer">{name}</a>
                </h3>
                <div class="text-sm uppercase tracking-[0.24em] text-neutral-500">
                  <time datetime={startDate} data-title={startDate}>{startYear}</time>
                  <span class="mx-2">—</span>
                  <time datetime={endDate} data-title={endDate} data-i18n={endDate == null ? 'experience.current' : undefined}>{endYear}</time>
                </div>
              </div>
              <p class="max-w-3xl text-sm leading-7 text-neutral-400" data-i18n={`experience.items.${index}.summary`}>{summary}</p>
            </div>
          </li>
        );
      })
    }
  </ul>
</Section>

<style>
  [data-title] {
    position: relative;
  }

  [data-title]:hover::after {
    opacity: 1;
    visibility: visible;
  }

  [data-title]::after {
    content: attr(data-title);
    position: absolute;
    left: 50%;
    bottom: -2rem;
    transform: translateX(-50%);
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: #0a0a0a;
    color: #f5f5f5;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease;
  }
</style>
