---
import Section from "../Section.astro";

import { work } from "@cv";
---

<Section title="Experiencia laboral" translationKey="sections.experience">
  <ul class="relative flex flex-col gap-4 border-l border-[color:var(--ds-border)] pl-6">
    {
      work.map(({ name, startDate, endDate, position, summary, url }, index) => {
        const startYear = new Date(startDate).getFullYear();
        const endYear = endDate != null ? new Date(endDate).getFullYear() : "Actual";

        return (
          <li class="ds-card relative p-5">
            <div class="absolute -left-[2.05rem] top-8 h-4 w-4 rounded-full border-4 border-white bg-blue-500 shadow dark:border-slate-900" />
            <h3 class="ds-item-title text-lg">
              <span data-i18n={`experience.items.${index}.position`}>{position}</span>{" "}
              <span class="ds-item-meta" data-i18n={`experience.items.${index}.at`}>en</span>{" "}
              <a class="underline decoration-blue-300 underline-offset-4 hover:text-blue-600 dark:hover:text-blue-300" href={url} target="_blank" rel="noopener noreferrer">{name}</a>
            </h3>
            <div class="mt-2 flex flex-wrap items-center gap-2 text-sm">
              <time class="ds-chip" datetime={startDate} data-title={startDate}>{startYear}</time>
              <span class="ds-subtle">—</span>
              <time
                class="ds-chip"
                datetime={endDate}
                data-title={endDate}
                data-i18n={endDate == null ? 'experience.current' : undefined}
              >
                {endYear}
              </time>
            </div>
            <p class="ds-copy mt-4 text-sm" data-i18n={`experience.items.${index}.summary`}>{summary}</p>
          </li>
        );
      })
    }
  </ul>
</Section>

<style>
  [data-title]:hover:after {
    opacity: 1;
    transition: all 0.1s ease-in-out 0.5s;
    visibility: visible;
  }

  [data-title]:after {
    content: attr(data-title);
    background-color: var(--ds-text);
    color: #fff;
    font-size: 0.75rem;
    position: absolute;
    padding: 0.2rem 0.5rem;
    bottom: -2rem;
    left: 50%;
    white-space: nowrap;
    box-shadow: var(--ds-shadow);
    opacity: 0;
    border: 1px solid var(--ds-border);
    z-index: 99999;
    visibility: hidden;
    border-radius: 0.75rem;
    transform: translateX(-50%);
  }

  [data-title] {
    position: relative;
  }
</style>
