---
import Section from "../Section.astro";

import { work } from "@cv";
---

<Section title="Experiencia laboral" translationKey="sections.experience" eyebrow="Journey">
  <ul class="relative border-s border-[var(--surface-border)] ps-2">
    {
      work.map(({ name, startDate, endDate, position, summary, url }, index) => {
        const startYear = new Date(startDate).getFullYear();
        const endYear = endDate != null ? new Date(endDate).getFullYear() : "Actual";

        return (
          <li class="mb-5 ms-4">
            <div class="absolute -start-1.5 mt-2 h-3 w-3 rounded-full border border-[var(--accent)] bg-[var(--accent)]/80" />
            <article class="info-card">
              <h3 class="item-title">
                <span data-i18n={`experience.items.${index}.position`}>{position}</span>{" "}
                <span data-i18n={`experience.items.${index}.at`}>en</span>{" "}
                <a class="text-[var(--accent)]" href={url} target="_blank" rel="noopener noreferrer">{name}</a>
              </h3>
              <div class="mt-2 flex items-center gap-2 text-sm font-semibold text-[var(--text-muted)]">
                <time datetime={startDate} data-title={startDate}>
                  {startYear}
                </time>
                <span>—</span>
                <time
                  datetime={endDate}
                  data-title={endDate}
                  data-i18n={endDate == null ? 'experience.current' : undefined}
                >
                  {endYear}
                </time>
              </div>
              <p class="item-copy" data-i18n={`experience.items.${index}.summary`}>{summary}</p>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>

<style>
  [data-title]:hover:after {
    opacity: 1;
    transition: all 0.1s ease-in-out 0.5s;
    visibility: visible;
  }

  [data-title]:after {
    content: attr(data-title);
    background-color: var(--surface-strong);
    color: var(--text-primary);
    font-size: 0.75rem;
    position: absolute;
    padding: 0.2rem 0.5rem;
    bottom: -1.8rem;
    left: 50%;
    white-space: nowrap;
    box-shadow: var(--shadow-soft);
    opacity: 0;
    border: 1px solid var(--surface-border);
    z-index: 99999;
    visibility: hidden;
    border-radius: 9999px;
    transform: translateX(-50%);
  }

  [data-title] {
    position: relative;
  }
</style>
