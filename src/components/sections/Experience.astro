---
import Section from "../Section.astro";

import { work } from "@cv";
---

<Section title="Experiencia laboral" translationKey="sections.experience">
  <div class="section-card px-6 py-6 lg:px-8">
  <ul class="relative border-s pl-2" style="border-color: var(--ds-border);">
    {
      work.map(({ name, startDate, endDate, position, summary, url }, index) => {
        const startYear = new Date(startDate).getFullYear();
        const endYear = endDate != null ? new Date(endDate).getFullYear() : "Actual";

        return (
          <li class="mb-5 ms-4">
            <div class="absolute -start-1.5 mt-2 h-3 w-3 rounded-full border" style="background: var(--ds-accent); border-color: var(--ds-accent);" />
            <h3 class="card-title mt-5">
              <span data-i18n={`experience.items.${index}.position`}>{position}</span>{" "}
              <span data-i18n={`experience.items.${index}.at`}>en</span>{" "}
              <a href={url} target="_blank" rel="noopener noreferrer">{name}</a>
            </h3>
            <time
              class="card-eyebrow min-w-25 cursor-default"
              datetime={startDate}
              data-title={startDate}
            >
              {startYear}
            </time>
            {" - "}
            <time
              class="card-eyebrow min-w-25 cursor-default"
              datetime={endDate}
              data-title={endDate}
              data-i18n={endDate == null ? 'experience.current' : undefined}
            >
              {endYear}
            </time>
            <p class="card-copy mt-3" data-i18n={`experience.items.${index}.summary`}>{summary}</p>
          </li>
        );
      })
    }
  </ul>
  </div>
</Section>

<style>
  [data-title]:hover:after {
    opacity: 1;
    transition: all 0.1s ease-in-out 0.5s;
    visibility: visible;
  }

  [data-title]:after {
    content: attr(data-title);
    background-color: var(--ds-surface-strong);
    color: var(--ds-text);
    font-size: 0.75rem;
    position: absolute;
    padding: 0.2rem 0.5rem;
    bottom: -1.4rem;
    left: 50%;
    white-space: nowrap;
    box-shadow: var(--ds-shadow);
    opacity: 0;
    border: 1px solid var(--ds-border);
    z-index: 99999;
    visibility: hidden;
    border-radius: 6px;
  }

  [data-title] {
    position: relative;
  }

  @media (width <= 700px) {
    time {
      text-align: right;
    }
  }
</style>
