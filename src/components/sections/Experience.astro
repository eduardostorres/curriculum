---
import Section from "../Section.astro";

import { work } from "@cv";
---

<Section title="Experiencia laboral" translationKey="sections.experience">
  <ul class="relative space-y-5 border-s border-slate-300/70 ps-6 dark:border-slate-700/80">
    {
      work.map(({ name, startDate, endDate, position, summary, url }, index) => {
        const startYear = new Date(startDate).getFullYear();
        const endYear = endDate != null ? new Date(endDate).getFullYear() : "Actual";

        return (
          <li class="relative">
            <div class="absolute -start-[1.95rem] top-6 h-3.5 w-3.5 rounded-full border-4 border-white bg-blue-600 shadow dark:border-slate-900 dark:bg-blue-400" />
            <article class="item-card">
              <header class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                <div>
                  <h3 class="item-title">
                    <span data-i18n={`experience.items.${index}.position`}>{position}</span>{" "}
                    <span data-i18n={`experience.items.${index}.at`}>en</span>{" "}
                    <a class="text-blue-700 hover:text-blue-600 dark:text-blue-300 dark:hover:text-blue-200" href={url} target="_blank" rel="noopener noreferrer">{name}</a>
                  </h3>
                </div>
                <div class="item-meta flex items-center gap-2 text-sm font-semibold">
                  <time datetime={startDate} data-title={startDate}>
                    {startYear}
                  </time>
                  <span>—</span>
                  <time
                    datetime={endDate}
                    data-title={endDate}
                    data-i18n={endDate == null ? "experience.current" : undefined}
                  >
                    {endYear}
                  </time>
                </div>
              </header>
              <p class="item-copy" data-i18n={`experience.items.${index}.summary`}>{summary}</p>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>

<style>
  [data-title]:hover:after {
    opacity: 1;
    transition: all 0.1s ease-in-out 0.5s;
    visibility: visible;
  }

  [data-title]:after {
    content: attr(data-title);
    background-color: #0f172a;
    color: #fff;
    font-size: 0.75rem;
    position: absolute;
    padding: 0.2rem 0.5rem;
    bottom: -1.7rem;
    left: 50%;
    white-space: nowrap;
    box-shadow: 0 8px 20px rgb(15 23 42 / 0.25);
    opacity: 0;
    border: 1px solid rgb(148 163 184 / 0.35);
    z-index: 99999;
    visibility: hidden;
    border-radius: 9999px;
    transform: translateX(-50%);
  }

  [data-title] {
    position: relative;
  }
</style>
