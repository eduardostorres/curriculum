---
import Section from "../Section.astro";

import { work } from "@cv";
---

<Section title="Experiencia laboral" translationKey="sections.experience">
  <ul class="grid gap-4">
    {
      work.map(({ name, startDate, endDate, position, summary, url }, index) => {
        const startYear = new Date(startDate).getFullYear();
        const endYear = endDate != null ? new Date(endDate).getFullYear() : "Actual";
        const bulletPoints = summary.split("\n\n");

        return (
          <li>
            <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md dark:border-slate-800 dark:bg-slate-900">
              <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                <header class="space-y-2">
                  <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-600 dark:text-sky-300">
                    {startYear} — <span data-i18n={endDate == null ? "experience.current" : undefined}>{endYear}</span>
                  </p>
                  <h3 class="text-xl font-bold text-slate-900 dark:text-white font-sans">
                    <span data-i18n={`experience.items.${index}.position`}>{position}</span>
                  </h3>
                  <p class="text-sm text-slate-500 dark:text-slate-400">
                    <span data-i18n={`experience.items.${index}.at`}>en</span>{" "}
                    <a class="font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-sky-600 dark:text-slate-200 dark:decoration-slate-700 dark:hover:text-sky-300" href={url} target="_blank" rel="noopener noreferrer">{name}</a>
                  </p>
                </header>
              </div>
              <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-600 dark:text-slate-300">
                {bulletPoints.map((point, pointIndex) => <li class="flex gap-3"><span class="mt-2 h-2 w-2 flex-none rounded-full bg-sky-500" /><span data-i18n={pointIndex === 0 ? `experience.items.${index}.summary` : undefined}>{point}</span></li>)}
              </ul>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>
