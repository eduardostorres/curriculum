---
import Section from "../Section.astro";

import AstroJs from "@/icons/logoastro.astro";
import Bootstrap from "@/icons/Bootstrap.astro";
import CSS from "@/icons/css.astro";
import Git from "@/icons/git.astro";
import GitHub from "@/icons/GitHub.astro";
import HTML from "@/icons/html.astro";
import JavaScript from "@/icons/javascript.astro";
import Laravel from "@/icons/laravel.astro";
import MySQL from "@/icons/sql.astro";
import PHP from "@/icons/php.astro";
import PostgreSQL from "@/icons/postgresql.astro";
import Tailwind from "@/icons/tailwind.astro";
import TypeScript from "@/icons/type.astro";
import VSCode from "@/icons/vscode.astro";

import { skills } from "@cv";

const SKILLS_ICONS: Record<string, any> = {
  HTML,
  CSS,
  JavaScript,
  TypeScript,
  MySQL,
  Git,
  GitHub,
  Tailwind,
  PHP,
  Laravel,
  Bootstrap,
  PostgreSQL,
  AstroJs,
  VSCode
};
---

<Section title="Habilidades" translationKey="sections.skills">
  <div class="rounded-2xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-900">
    <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {
        skills.map(({ name }) => {
          const iconName = name === "Next.js" ? "Next" : name;
          const Icon = SKILLS_ICONS[iconName];

          return (
            <li class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-600 dark:border-slate-700 dark:bg-transparent dark:text-slate-200">
              <span class="text-sky-600 dark:text-sky-300">{Icon && <Icon />}</span>
              <span class="font-medium">{name}</span>
            </li>
          );
        })
      }
    </ul>
  </div>
</Section>
