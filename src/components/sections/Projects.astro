---
import GitHub from "@/icons/GitHub.astro";
import Section from "../Section.astro";

import { projects } from "@cv";
---

<Section title="Proyectos">
  <ul class="grid gap-4 md:grid-cols-2">
    {
      projects.map(({ url, description, highlights, name, isActive, github }) => {
        return (
          <li>
            <article class="flex h-full flex-col rounded-xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-700 dark:bg-gray-900">
              <header class="flex-1">
                <div class="flex items-center gap-2">
                  <h3 class="text-lg font-bold text-gray-700 dark:text-gray-100 font-sans">
                    <a href={url} target="_blank" rel="noopener noreferrer" title={`Ver el proyecto ${name}`}>
                      {name}
                    </a>
                  </h3>
                  {isActive && <span class="inline-flex h-2.5 w-2.5 rounded-full bg-emerald-500" aria-label="Proyecto activo" />}
                  {github && (
                    <a
                      class="text-gray-400 transition hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300"
                      href={github}
                      target="_blank"
                      rel="noopener noreferrer"
                      title={`Ver código fuente del proyecto ${name}`}
                    >
                      <GitHub />
                    </a>
                  )}
                </div>
                <p class="mt-3 text-sm leading-6 text-gray-500 dark:text-gray-300">{description}</p>
              </header>
              <footer class="mt-4 flex flex-wrap gap-2">
                {highlights.map((highlight) => <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-300">{highlight}</span>)}
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>
