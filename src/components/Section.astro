---
interface Props {
  title?: string;
  translationKey?: string;
}

const { title, translationKey } = Astro.props;
---

<section class="mx-auto mt-6 max-w-5xl surface-card section-card">
  {
    title && (
      <h2 class="section-heading" data-i18n={translationKey}>
        {title}
      </h2>
    )
  }
  <slot />
</section>
