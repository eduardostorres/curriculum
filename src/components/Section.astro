---
interface Props {
  title?: string;
  translationKey?: string;
}

const { title, translationKey } = Astro.props;
---

<section class="section-shell mt-6">
  {
    title && (
      <h2
        class="section-heading mb-5 mt-8 px-1"
        data-i18n={translationKey}
      >
        {title}
      </h2>
    )
  }
  <slot />
</section>
