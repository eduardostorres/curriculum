---
interface Props {
  title?: string;
  translationKey?: string;
  sectionId?: string;
}

const { title, translationKey, sectionId } = Astro.props;
---

<section id={sectionId} data-section-id={sectionId} class="m-auto mt-2 max-w-4xl scroll-mt-28">
  {
    title && (
      <h2
        class="font-bold mt-8 text-3xl font-sans"
        data-i18n={translationKey}
      >
        {title}
      </h2>
    )
  }
  <slot />
</section>
