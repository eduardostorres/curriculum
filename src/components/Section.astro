---
interface Props {
  title?: string;
  translationKey?: string;
  eyebrow?: string;
}

const { title, translationKey, eyebrow } = Astro.props;
---

<section class="section-shell">
  {
    (eyebrow || title) && (
      <header>
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        {title && (
          <h2 class="section-title" data-i18n={translationKey}>
            {title}
          </h2>
        )}
      </header>
    )
  }
  <slot />
</section>
